/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model interview_answers {
  answer_id                    String                         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  attempt_id                   String                         @db.Uuid
  question_id                  String?                        @db.Uuid
  answer_text                  String?
  answer_payload               Json?
  answered_at                  DateTime                       @default(now()) @db.Timestamptz(6)
  session_question_id          String?                        @db.Uuid
  answer_evaluations           answer_evaluations[]
  interview_answer_evaluations interview_answer_evaluations[]
  interview_attempts           interview_attempts             @relation(fields: [attempt_id], references: [attempt_id], onDelete: Cascade, onUpdate: NoAction)
  questions                    questions?                     @relation(fields: [question_id], references: [question_id], onDelete: NoAction, onUpdate: NoAction)
  session_questions            session_questions?             @relation(fields: [session_question_id], references: [session_question_id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([attempt_id, question_id], map: "uq_attempt_question")
  @@unique([attempt_id, question_id], map: "uq_attempt_question_answer")
  @@unique([attempt_id, question_id], map: "uq_interview_answers_attempt_question")
  @@index([attempt_id], map: "idx_answers_attempt")
}

