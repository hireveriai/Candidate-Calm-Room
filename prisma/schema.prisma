  interview_id        String?            @db.Uuid
  interview_attempts  interview_attempts @relation(fields: [attempt_id], references: [attempt_id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model interview_attempts {
  attempt_id                  String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  interview_id                String                       @db.Uuid
  attempt_number              Int
  started_at                  DateTime                     @default(now()) @db.Timestamptz(6)
  ended_at                    DateTime?                    @db.Timestamptz(6)
  status                      String                       @default("started")
  candidate_experience        String?
  mission_snapshot_id         String?                      @db.Uuid
  attempt_question_map        attempt_question_map[]
  attempt_skill_scores        attempt_skill_scores[]
  candidate_resume_ai         candidate_resume_ai[]
  interview_answers           interview_answers[]
  interview_attempt_scores    interview_attempt_scores?
  interviews                  interviews                   @relation(fields: [interview_id], references: [interview_id], onDelete: Cascade, onUpdate: NoAction)
  interview_mission_snapshots interview_mission_snapshots? @relation(fields: [mission_snapshot_id], references: [snapshot_id], onDelete: NoAction, onUpdate: NoAction)
  interview_evaluations       interview_evaluations?
  interview_results           interview_results[]
  resume_reality_gap          resume_reality_gap[]
  session_questions           session_questions[]

  @@unique([interview_id, attempt_number], map: "uq_interview_attempt")
  @@unique([interview_id, attempt_number], map: "uq_interview_attempts_interview_attempt")
  @@index([interview_id, status], map: "idx_attempt_interview_status")
}

