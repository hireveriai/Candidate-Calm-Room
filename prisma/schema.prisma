generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model ai_audit_logs {
  audit_id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entity_type      String?
  entity_id        String?   @db.Uuid
  ai_provider      String?
  request_payload  Json?
  response_payload Json?
  created_at       DateTime? @default(now()) @db.Timestamptz(6)
}

model ai_signed_decisions {
  decision_id      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  attempt_id       String    @db.Uuid
  decision_type    String
  decision_value   String
  ai_model         String
  ai_model_version String
  confidence       Float
  signed_hash      String
  signed_at        DateTime? @default(now()) @db.Timestamptz(6)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model answer_evaluations {
  evaluation_id     String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  answer_id         String?            @db.Uuid
  skill_id          String?            @db.Uuid
  raw_score         Decimal?           @db.Decimal(5, 2)
  rubric_reason     String?
  evaluated_by      String?            @default("AI")
  evaluated_at      DateTime?          @default(now()) @db.Timestamptz(6)
  interview_answers interview_answers? @relation(fields: [answer_id], references: [answer_id], onDelete: NoAction, onUpdate: NoAction)
  skill_master      skill_master?      @relation(fields: [skill_id], references: [skill_id], onDelete: NoAction, onUpdate: NoAction)

  @@index([answer_id], map: "idx_eval_answer")
}

model attempt_question_map {
  attempt_id         String             @db.Uuid
  question_id        String             @db.Uuid
  interview_attempts interview_attempts @relation(fields: [attempt_id], references: [attempt_id], onDelete: NoAction, onUpdate: NoAction)
  questions          questions          @relation(fields: [question_id], references: [question_id], onDelete: NoAction, onUpdate: NoAction)

  @@id([attempt_id, question_id])
}

model attempt_skill_scores {
  attempt_id         String             @db.Uuid
  skill_id           String             @db.Uuid
  normalized_score   Decimal?           @db.Decimal(5, 2)
  interview_attempts interview_attempts @relation(fields: [attempt_id], references: [attempt_id], onDelete: NoAction, onUpdate: NoAction)
  skill_master       skill_master       @relation(fields: [skill_id], references: [skill_id], onDelete: NoAction, onUpdate: NoAction)

  @@id([attempt_id, skill_id])
  @@index([attempt_id], map: "idx_attempt_skill_attempt")
}

model audit_logs {
  log_id     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String?   @db.Uuid
  action     String?
  metadata   Json?
  created_at DateTime? @default(now()) @db.Timestamptz(6)
}

model auth_intent_pool {
  auth_intent_id Int       @id @db.SmallInt
  code           String    @unique
  description    String?
  created_at     DateTime? @default(now()) @db.Timestamptz(6)
}

model auth_sessions {
  session_id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  identity_id         String?         @unique(map: "ux_signup_session_per_identity", where: raw("((auth_intent_id = 2) AND (is_active = true))")) @db.Uuid
  issued_at           DateTime?       @default(now()) @db.Timestamptz(6)
  expires_at          DateTime        @db.Timestamptz(6)
  ip_address          String?
  user_agent          String?
  is_active           Boolean?        @default(true)
  signup_user_type_id Int?            @db.SmallInt
  auth_intent_id      Int             @default(1) @db.SmallInt
  identity_users      identity_users? @relation(fields: [identity_id], references: [identity_id], onDelete: Cascade, onUpdate: NoAction)
  user_type_pool      user_type_pool? @relation(fields: [signup_user_type_id], references: [user_type_id], onDelete: NoAction, onUpdate: NoAction)

  @@index([session_id], map: "idx_auth_sessions_active", where: raw("(is_active = true)"))
  @@index([session_id], map: "idx_auth_sessions_signup_valid", where: raw("((auth_intent_id = 2) AND (signup_user_type_id IS NOT NULL) AND (is_active = true))"))
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model candidate_hire_prediction {
  candidate_id      String    @db.Uuid
  interview_id      String    @db.Uuid
  prediction_score  Decimal?  @db.Decimal(5, 2)
  confidence_level  String?
  prediction_reason Json?
  created_at        DateTime? @default(now()) @db.Timestamptz(6)

  @@id([candidate_id, interview_id])
}

model candidate_profiles {
  candidate_id          String                 @id @db.Uuid
  career_track_id       Int                    @db.SmallInt
  experience_level_id   Int?                   @db.SmallInt
  created_at            DateTime?              @default(now()) @db.Timestamptz(6)
  users                 users                  @relation(fields: [candidate_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
  career_track_pool     career_track_pool      @relation(fields: [career_track_id], references: [career_track_id], onDelete: NoAction, onUpdate: NoAction)
  experience_level_pool experience_level_pool? @relation(fields: [experience_level_id], references: [experience_level_id], onDelete: NoAction, onUpdate: NoAction)
}

model candidate_resume_ai {
  resume_ai_id             String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  interview_id             String?             @db.Uuid
  attempt_id               String?             @db.Uuid
  raw_resume               String?
  extracted_skills         String[]
  claimed_experience_years Int?
  extracted_claims         Json?
  created_at               DateTime?           @default(now()) @db.Timestamptz(6)
  interview_attempts       interview_attempts? @relation(fields: [attempt_id], references: [attempt_id], onDelete: NoAction, onUpdate: NoAction)
  interviews               interviews?         @relation(fields: [interview_id], references: [interview_id], onDelete: NoAction, onUpdate: NoAction)
}

model candidate_skill_profile {
  candidate_id  String   @db.Uuid
  skill_id      String   @db.Uuid
  avg_score     Decimal? @db.Decimal(5, 2)
  attempt_count Int?

  @@id([candidate_id, skill_id])
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model candidates {
  candidate_id    String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String        @db.Uuid
  full_name       String
  email           String
  phone           String?
  created_at      DateTime      @default(now()) @db.Timestamptz(6)
  organizations   organizations @relation(fields: [organization_id], references: [organization_id], onDelete: NoAction, onUpdate: NoAction)
  interviews      interviews[]

  @@unique([organization_id, email], map: "uq_candidates_org_email")
}

model career_track_pool {
  career_track_id    Int                  @id @db.SmallInt
  code               String               @unique
  description        String?
  is_active          Boolean?             @default(true)
  created_at         DateTime?            @default(now()) @db.Timestamptz(6)
  candidate_profiles candidate_profiles[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model company_skill_baseline {
  organization_id String @db.Uuid
  job_id          String @db.Uuid
